	(text "Only use ABM8-272-T3 crystal.\nPlace capacitors close to crystal.\nCrystal needs 10 pF load capacitance:\n - two 15 pF in series = 7.5 pF\n - assume 3 pF in parasitic capacitance from the XIN/XOUT traces\nCapacitors don't need to be C0G (but the JLC Basic part is)"
		(exclude_from_sim no)
		(at 179.578 192.786 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "fe163a8d-1e5b-47c9-b937-de0eca669494")
	)
