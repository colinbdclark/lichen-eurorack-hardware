	(text "The bulk capacitance is tripled here \nbecause these ceramic caps derate to \n3.54V with an 11.9V DC bias (-64.6%).\nSchottkys diodes have been substituted \nwith a JLC Basic part."
		(exclude_from_sim no)
		(at 115.316 454.406 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "0dc1c481-2981-44ea-9461-91870185d416")
	)
	(text "Power circuit adapted from Paul Schreiber."
		(exclude_from_sim no)
		(at 95.25 444.246 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "354834c8-b928-4710-816b-aab833f32fcd")
	)
	(text "Note, in paults' schematic,\nthe ferrite bead he uses is a Murata BLM21PG221SN1D\nwhich is 220R@100MHz.\nThis part (120R@100MHz) is substituted because it's JLC Basic,\nbut may not be as suitable a part."
		(exclude_from_sim no)
		(at 115.57 466.344 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "35fbe945-844b-493f-a262-0d552afeec6a")
	)
