	)
	(text "Note, in paults' schematic,\nthe ferrite bead he uses is a Murata BLM21PG221SN1D\nwhich is 220R@100MHz.\nThis part (120R@100MHz) is substituted because it's JLC Basic,\nbut may not be as suitable a part.\nHe also specifies STM STPS1L30U for the Schottky diode, which has been\nsubstituted here for a JLC basic Schottkey diode instead."
		(exclude_from_sim no)
		(at 94.996 76.2 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "af98e947-a53f-45fb-9e22-242d78556f3d")
	)
