	(text "Dual ideal diode allows\nfor Eurorack and USB power\nto be connected at the same time."
		(exclude_from_sim no)
		(at 162.052 64.516 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "2edac676-a1e1-4515-a54d-eeacf62d708c")
	)
	(text "R1 = top resistor, connected to SW\nR2 = bottom resistor, connected to GND\n\nVfb = 0.8V\nR1 = R2 * (Vout / Vfb - 1)\nVout = Vfb * (R1/R2 + 1)\n\nVout ideal = 5V\nR1 = R2 * 5.25\n\nR2 = 56K\nR1 = 56 * 5.25 = 294K = 300K\n\nVout actual = 0.8 * (300/56+1) = 5.09V"
		(exclude_from_sim no)
		(at 113.284 122.428 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "360b241d-44a7-40a0-aad9-cc54e7dba8d2")
	)
