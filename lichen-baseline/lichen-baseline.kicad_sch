	(text "Place 27R termination resistors close to MCU pins.\n90Ω differential characteristic impedance for D+/-.\nEnsure a solid ground pour directly beneath the pair."
		(exclude_from_sim no)
		(at 277.622 122.682 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "58fea6c8-d8ac-4e27-9c1c-4f6796077aff")
	)
	(text "See page 448 of RP2350\nDatasheet and page 7 of\nHardware Design Guide\nfor PCB layout guidelines\nfor high switching current\npaths"
		(exclude_from_sim no)
		(at 110.1953 93.8558 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify right)
		)
		(uuid "7f847d98-5024-4cfb-a5ef-8bf696b5d645")
	)
	(text "Only use ABM8-272-T3 crystal.\nPlace capacitors close to crystal.\nCrystal needs 10 pF load capacitance:\n - two 15 pF in series = 7.5 pF\n - assume 3 pF in parasitic capacitance from \n   the XIN/XOUT traces\nCapacitors don't need to be C0G \n(but the JLC Basic part is)"
		(exclude_from_sim no)
		(at 58.42 196.088 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "8d4bdfb5-0d3c-4d65-a00e-e8766043e905")
	)
