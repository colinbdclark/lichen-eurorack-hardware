	(text "DAC input antialiasing LPF cutoff: 159 KHz"
		(exclude_from_sim no)
		(at 36.322 151.384 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "1dbe099b-60dd-4113-b3d7-d3a3b1929f3c")
	)
	(text "DAC output LPF cutoff: 159 KHz\nThis filter uses different component values than the datasheet\nso that it's consistent with the ADC,\nbut the cutoff frequency is very similar."
		(exclude_from_sim no)
		(at 157.226 153.67 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "3d53be3b-51e3-47f2-8628-e62e154cef0d")
	)
	(text "ADC"
		(exclude_from_sim no)
		(at 18.542 26.67 0)
		(effects
			(font
				(size 2.54 2.54)
				(thickness 0.508)
				(bold yes)
			)
		)
		(uuid "4e362f64-63df-44fa-b776-156c4255ab58")
	)
	(text "22uF ceramic capacitors are used instead of 10uF electrolytic,\ntaking into account a 32% derating when biased at 3.3V DC.\nThis means we've got more like 14.1uF bypass capacitance on all power pins."
		(exclude_from_sim no)
		(at 157.226 144.018 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "8b4e0061-da9a-48e9-b233-a47b5503c4ed")
	)
	(text "I2S Pins: DIN to GPIO13, BCLK to GPIO14, LRCLK to GPIO15\nDEMP: Low to disable the De-emphasis filter (which is fixed to a 44.1KHz sample rate)\nFMT: Low for I2S format\nXSMT: Pull high to unmoute the DAC (connect to GPIO)\nFLT: Interpolation filter, pull low for IIR low-latency"
		(exclude_from_sim no)
		(at 157.48 132.842 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "9a4bed1d-2b60-4266-8d54-02ffc40fdf5b")
	)
	(text "MD1 Low: I2C Address 0x94"
		(exclude_from_sim no)
